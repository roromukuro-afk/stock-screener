# アプリ環境 (local / production)
APP_ENV=local

# データベース
# ローカル(SQLite):
DATABASE_URL=sqlite:///./screener.db
# 本番(PostgreSQL)例:
# DATABASE_URL=postgresql://USER:PASS@HOST:5432/DBNAME

# CORS: フロントエンドの公開URL (カンマ区切りで複数指定可能)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Vercel preview URLなどを許可する場合:
# ALLOWED_ORIGIN_REGEX=https://.*\.vercel\.app

# yfinance有効化(false にすると常にサンプルモード)
YFINANCE_ENABLED=true

# 強制サンプルモード (本番起動時のフォールバック用)
SAMPLE_MODE=false

# 為替フォールバック値
DEFAULT_USDJPY=155

# 公開URL(deploy-statusに表示するためのヒント)
FRONTEND_URL=
BACKEND_URL=

# 自動化パイプライン (GitHub Actions Cron 用)
# 任意の長いランダム文字列を設定 (例: openssl rand -hex 32)
CRON_SECRET=

# ===== ローカル直結CLI (本番PostgreSQL) =====
# 重い surge-20 学習処理をローカルPCで実行し本番DBに直接書き込む運用。
# このファイルを手で編集せず、対話セットアップを実行すると確実です:
#   python scripts/setup_local_training.py
#   (PowerShell: .\scripts\setup_local_training.ps1)
# → backend/.env.local-training を生成 (git追跡されません / 秘密はprintしません)。
#
# DATABASE_URL の解決優先順位:
#   1. 環境変数 DATABASE_URL
#   2. LOCAL_TRAINING_ENV_FILE で指定したファイル
#   3. backend/.env.local-training
#   4. backend/.env
#   5. SQLite フォールバック (sqlite:///./screener.db)
# postgres:// は postgresql:// に正規化され sslmode=require が自動付与されます。
